# ============================================================================
# Misión Geneo — Variables de entorno
# ----------------------------------------------------------------------------
# Copiá este archivo a la RAÍZ del proyecto (mision-geneo/) como `.env.local`
# y completá los valores. Ver SETUP.md para el paso a paso.
#
#   cp supabase/env.local.example .env.local
# ============================================================================

# --- Públicas (se exponen al navegador; NEXT_PUBLIC_*) ---
# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase → Project Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- SECRETA (solo server-side; NUNCA con prefijo NEXT_PUBLIC_) ---
# Supabase → Project Settings → API → Project API keys → service_role
# Saltea RLS: usar solo en el servidor. NO commitear el valor real.
SUPABASE_SERVICE_ROLE_KEY=
